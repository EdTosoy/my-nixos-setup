// Place your key bindings in this file to override the defaults
//
// DVORAK REMAP — only keys that physically moved are updated.
// QWERTY → Dvorak: q→' w→, e→. r→p t→y y→f u→g i→c o→r p→l
//                  a→a s→o d→e f→u g→i h→d j→h k→t l→n n→b b→x m→m
[
  // =============================
  // ======= LEADER BINDS ========
  // =============================
  {
    "key": "space ,", // [W]rite current file (w→,)
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.files.save",
        "editor.action.formatDocument"
      ]
    },
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space e", // save without formatting (d→e)
    "command": "workbench.action.files.saveWithoutFormatting",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space i i", // [G]it (g→i)
    "args": {
      "commands": ["workbench.view.scm", "workbench.scm.focus"]
    },
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space ;", // [Q]uit (q→')
    "command": "workbench.action.closeActiveEditor",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space c a", // [C]ode [A]ction
    "command": "editor.action.codeAction",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space p b", // [R]e[n]ame (r→p, n→b)
    "command": "editor.action.rename",
    "when": "neovim.mode == 'normal' && editorHasRenameProvider && editorTextFocus && !editorReadonly"
  },
  {
    "key": "space i o", // [G]o to [S]ymbol (g→i, s→o)
    "command": "workbench.action.gotoSymbol",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space u u", // [F]ind [F]ile (f→u)
    "command": "workbench.action.quickOpen",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space u i", // [F]ind [G]rep (f→u, g→i)
    "command": "workbench.action.findInFiles",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space i e", // [G]o to [D]efinition (g→i, d→e)
    "command": "editor.action.revealDefinition",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space i p", // [G]o to [R]eferences (g→i, r→p)
    "command": "editor.action.goToReferences",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space i c", // [G]o to [I]mplementation (g→i, i→c)
    "command": "editor.action.goToImplementation",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "[ e", // Prev diagnostics (d→e)
    "command": "editor.action.marker.prev",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "] e", // Next diagnostics (d→e)
    "command": "editor.action.marker.next",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space o", // [S]plit side (s→o)
    "command": "workbench.action.splitEditorRight",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space k", // split down
    "command": "workbench.action.splitEditorDown",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "shift+t", // show hover (k→t)
    "command": "editor.action.showHover",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space u m", // [F]or[m]at (f→u, m→m)
    "command": "editor.action.formatDocument",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  // ================================
  // ======= PANE MANAGEMENT ========
  // ================================
  {
    "key": "ctrl+h",
    "command": "workbench.action.navigateLeft"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.navigateDown"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.navigateUp"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.navigateRight"
  },
  // ========================
  // ======= BUFFERS ========
  // ========================
  {
    "key": "tab",
    "command": "workbench.action.nextEditorInGroup",
    "when": "(neovim.mode == 'normal' || neovim.mode == 'visual') && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "shift+tab",
    "command": "workbench.action.previousEditorInGroup",
    "when": "(neovim.mode == 'normal' || neovim.mode == 'visual') && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space y", // close other editors (t→y)
    "command": "workbench.action.closeOtherEditors",
    "when": "(neovim.mode == 'normal' || neovim.mode == 'visual') && (editorTextFocus || !inputFocus)"
  },
  // ==========================
  // ======= FILE TREE ========
  // ==========================
  {
    "key": "space .", // explorer (e→. in dvorak)
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.toggleSidebarVisibility",
        "workbench.files.action.focusFilesExplorer"
      ]
    },
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus) && !sideBarFocus"
  },
  {
    "key": "space .",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.toggleSidebarVisibility",
        "workbench.action.focusActiveEditorGroup"
      ]
    },
    "when": "sideBarFocus && !inputFocus"
  },
  {
    "key": "space .",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "neovim.mode == 'normal' && editorTextFocus && foldersViewVisible"
  },
  {
    "key": "p", // rename (r→p)
    "command": "renameFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "c", // copy
    "command": "filesExplorer.copy",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "l", // paste (p→l)
    "command": "filesExplorer.paste",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "x", // cut
    "command": "filesExplorer.cut",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "e", // delete (d→e)
    "command": "deleteFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "a", // new file
    "command": "explorer.newFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "shift+a", // new folder
    "command": "explorer.newFolder",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "o", // open to side (s→o)
    "command": "explorer.openToSide",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "shift+o", // open split down
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.splitEditorDown",
        "explorer.openAndPassFocus",
        "workbench.action.closeOtherEditors"
      ]
    },
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },
  {
    "key": "enter",
    "command": "explorer.openAndPassFocus",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceIsFolder && !inputFocus"
  },
  {
    "key": "enter",
    "command": "list.toggleExpand",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && explorerResourceIsFolder && !inputFocus"
  },
  {
    "key": "ctrl+b", // toggle sidebar (n→b)
    "command": "workbench.action.toggleSidebarVisibility"
  },
  // =========================
  // ======= TERMINAL ========
  // =========================
  {
    "key": "ctrl+shift+j",
    "command": "workbench.action.togglePanel"
  },
  {
    "key": "ctrl+shift+x", // focus next terminal (b→x)
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+shift+a", // focus prev terminal
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+shift+b", // new terminal (n→b)
    "command": "workbench.action.terminal.new",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+shift+'", // kill terminal (q→')
    "command": "workbench.action.terminal.kill",
    "when": "terminalFocus"
  },
  // =======================
  // ======= EDITOR ========
  // =======================
  {
    "key": "tab",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  {
    "key": "down",
    "command": "-selectNextSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  {
    "key": "tab",
    "command": "-acceptSelectedSuggestion",
    "when": "suggestWidgetHasFocusedSuggestion && suggestWidgetVisible && textInputFocus"
  },
  {
    "key": "shift+tab",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  {
    "key": "up",
    "command": "-selectPrevSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus || suggestWidgetVisible && textInputFocus && !suggestWidgetHasFocusedSuggestion"
  },
  {
    "key": "tab",
    "command": "quickInput.next",
    "when": "inQuickInput && quickInputType == 'quickPick'"
  },
  {
    // Doesn't work at the moment.
    // Accessibility keybinds with "shift" when quickInput is open causes interference.
    // https://github.com/microsoft/vscode/issues/180862
    "key": "shift+tab",
    "command": "quickInput.previous",
    "when": "inQuickInput && quickInputType == 'quickPick'"
  },
  {
    "key": "escape",
    "command": "closeMarkersNavigation",
    "when": "editorFocus && markersNavigationVisible"
  },
  {
    "key": "tab",
    "command": "selectNextCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "down",
    "command": "-selectNextCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "shift+tab",
    "command": "selectPrevCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "up",
    "command": "-selectPrevCodeAction",
    "when": "codeActionMenuVisible"
  },
  {
    "key": "cmd+b", // (n→b)
    "command": "-workbench.action.files.newUntitledFile"
  },
  // ========================
  // ======= HARPOON ========
  // ========================
  {
    "key": "space a", // add harpoon
    "command": "vscode-harpoon.addEditor",
    "when": "neovim.mode == 'normal' && editorTextFocus"
  },
  {
    "key": "space d", // harpoon file list (h→d)
    "command": "vscode-harpoon.editEditors",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space l", // harpoon quick pick (p→l)
    "command": "vscode-harpoon.editorQuickPick",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space 1",
    "command": "vscode-harpoon.gotoEditor1",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space 2",
    "command": "vscode-harpoon.gotoEditor2",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space 3",
    "command": "vscode-harpoon.gotoEditor3",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space 4",
    "command": "vscode-harpoon.gotoEditor4",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  {
    "key": "space 5",
    "command": "vscode-harpoon.gotoEditor5",
    "when": "neovim.mode == 'normal' && (editorTextFocus || !inputFocus)"
  },
  // ================================
  // ======= CTRL PASSTHROUGH ========
  // ================================
  {
    "key": "ctrl+a",
    "command": "editor.action.selectAll",
    "when": "editorTextFocus && neovim.mode == 'normal'"
  },
  {
    "key": "ctrl+f",
    "command": "actions.find",
    "when": "editorTextFocus && neovim.mode == 'normal'"
  }
]
